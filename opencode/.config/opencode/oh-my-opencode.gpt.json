{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "disabled_hooks": [
    "no-sisyphus-gpt",
    "no-hephaestus-non-gpt"
  ],
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "librarian": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "explore": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "atlas": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "allow_non_gpt_model": true
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "artistry": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "quick": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "writing": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    }
  }
}
